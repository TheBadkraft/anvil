{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug active test (make: build active test)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "gcc: link active test"
        },
        {
            "name": "Debug CLI",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/anvil",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "Build CLI"
        },
        {
            "name": "Debug test_parser",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/test_parser",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}
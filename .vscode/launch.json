{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug active test (make: build active test)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/test/unit/bin/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/test/unit",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "link active test"
        }
    ]
}
{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "testPath",
            "description": "Test path (e.g. unit/parser, unit, performance)",
            "default": "unit",
            "type": "promptString"
        }
    ],
    "tasks": [
        {
            "label": "cpkg: anvil",
            "type": "shell",
            "command": "cpkg anvil && sudo cp package/anvil.o /usr/local/packages/anvil.o",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "cbuild: lib",
            "type": "shell",
            "command": "cbuild",
            "args": [
                "lib"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "cbuild: compile",
            "type": "shell",
            "command": "cbuild",
            "args": [
                "compile"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "cbuild: clean",
            "type": "shell",
            "command": "cbuild",
            "args": [
                "clean"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "cbuild: clean_all",
            "type": "shell",
            "command": "cbuild",
            "args": [
                "clean_all"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "rtest: prompt",
            "type": "shell",
            "command": "./rtest",
            "args": [
                "${input:testPath}"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": [
                "cbuild: lib"
            ]
        },
        {
            "label": "rtest: unit",
            "type": "shell",
            "command": "./rtest",
            "args": [
                "unit"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": [
                "cbuild: lib"
            ]
        },
        {
            "label": "rtest: performance",
            "type": "shell",
            "command": "./rtest",
            "args": [
                "performance"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": [
                "cbuild: lib"
            ]
        },
        {
            "label": "rtest: active test",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "name=$(basename '${fileBasenameNoExtension}' | sed 's/^test_//'); subdir=$(dirname '${relativeFile}' | sed 's|^test/||;s|/.*||'); ./rtest ${subdir}/${name}"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": [
                "cbuild: lib"
            ]
        },
        {
            "label": "rtest: active test (valgrind)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "name=$(basename '${fileBasenameNoExtension}' | sed 's/^test_//'); subdir=$(dirname '${relativeFile}' | sed 's|^test/||;s|/.*||'); ./rtest ${subdir}/${name} --valgrind"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": [
                "cbuild: lib"
            ]
        }
    ]
}
@config_block = `
version: 2.0
database:
  primary:
    host: db-primary.example.com
    port: 5432
    replicas:
      - db-replica-1.example.com:5432
      - db-replica-2.example.com:5432
  cache:
    redis_nodes:
      - node1:6379
      - node2:6379
    ttl_seconds: 3600
logging:
  level: INFO
  outputs:
    - type: file
      path: /var/log/app.log
      rotation: daily
    - type: elasticsearch
      hosts: [es1:9200, es2:9200]
`

// large.aml — deterministic benchmark fixture  (~500 lines)
// Covers: vars block, 20 block definitions, biome list, inventory tuples,
//         inheritance chains, blobs, mixed scalar types.
#!aml

vars {
    default_hardness    := 5
    default_resistance  := 6.0
    default_drop_chance := 0.75
    atlas               := terrain.png
    base_path           := assets/textures/blocks
    sounds_path         := assets/sounds
    mod_id              := benchmark_mod
    spawn_world         := overworld
    max_stack           := 64
    tool_level          := 0
}


/* Very large nested structure test */
@[version: "1.0.0", author: "test-suite"]

data_warehouse := {
    schemas: [
        {
            name: "events"
            tables: [
                { name: "clicks", columns: ["timestamp", "user_id", "page_id", "x", "y", "device"] }
                { name: "impressions", columns: ["timestamp", "campaign_id", "user_id", "position"] }
                { name: "conversions", columns: ["timestamp", "user_id", "product_id", "amount", "currency"] }
            ]
        }
        {
            name: "users"
            tables: [
                { name: "profiles", columns: ["user_id", "name", "email", "created_at", "updated_at"] }
                { name: "preferences", columns: ["user_id", "theme", "language", "notifications"] }
                { name: "sessions", columns: ["session_id", "user_id", "start_time", "end_time", "ip_address"] }
            ]
        }
        {
            name: "products"
            tables: [
                { name: "catalog", columns: ["product_id", "sku", "name", "category", "price"] }
                { name: "inventory", columns: ["product_id", "warehouse_id", "quantity", "reserved"] }
                { name: "reviews", columns: ["review_id", "product_id", "user_id", "rating", "text"] }
            ]
        }
    ]
    
    indexes: [
        { name: "idx_events_timestamp", schema: "events", table: "clicks", columns: ["timestamp"] }
        { name: "idx_events_user", schema: "events", table: "clicks", columns: ["user_id"] }
        { name: "idx_users_email", schema: "users", table: "profiles", columns: ["email"], unique: true }
        { name: "idx_products_sku", schema: "products", table: "catalog", columns: ["sku"], unique: true }
    ]
    
    backups: [
        { timestamp: 1702500000, size_mb: 1024, status: "complete", location: "s3://backups/2023-12-14" }
        { timestamp: 1702413600, size_mb: 1018, status: "complete", location: "s3://backups/2023-12-13" }
        { timestamp: 1702327200, size_mb: 1022, status: "complete", location: "s3://backups/2023-12-12" }
        { timestamp: 1702240800, size_mb: 1020, status: "complete", location: "s3://backups/2023-12-11" }
    ]
}

metrics := {
    cpu_usage: [45, 48, 52, 51, 49, 50, 46, 47, 51, 52, 50, 49, 48, 47, 46, 45, 44, 43, 42, 41]
    memory_usage: [65, 66, 67, 68, 69, 70, 71, 70, 69, 68, 67, 66, 65, 64, 63, 62, 61, 60, 59, 58]
    disk_io: [120, 125, 130, 128, 126, 124, 122, 120, 118, 116, 114, 112, 110, 108, 106, 104, 102, 100, 98, 96]
    network: [250, 260, 270, 280, 290, 300, 310, 320, 310, 300, 290, 280, 270, 260, 250, 240, 230, 220, 210, 200]
}

settings := {
    security: {
        enable_2fa: true
        password_min_length: 12
        password_expiry_days: 90
        session_timeout_minutes: 30
        max_login_attempts: 5
    }
    performance: {
        cache_enabled: true
        compression: "gzip"
        batch_size: 1000
        timeout_seconds: 30
        retry_count: 3
        retry_delay_ms: 100
    }
    notifications: {
        enabled: true
        channels: ["email", "slack", "webhook"]
        batch_interval_seconds: 60
        max_retries: 5
    }
}
